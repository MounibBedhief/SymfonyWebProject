{% extends 'base.html.twig' %}

{% block stylesheets %}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link rel="stylesheet" href="{{ asset('css/style.css') }}">
<link rel="stylesheet" href="{{ asset('css/rechercher_docteurs.css') }}">
{% endblock %}

{% block body %}
<header class="navbar">
  <div class="logo">Health <span>Connect</span></div>
  <nav class="nav-links">
    <a href="{{ path('home') }}#services">Services</a>
    <a href="{{ path('home') }}#howitworks">How It Works</a>
    <a href="{{ path('home') }}#doctors">Our Doctors</a>
    <a href="{{ path('home') }}#about">About</a>
  </nav>
  <div class="nav-actions">
    <a href="{{ path('login') }}" class="signin">Sign In</a>
    <a href="{{ path('dashboard') }}" class="btn">Dashboard</a>
    <a href="{{ path('appointments_book') }}" class="btn">Book Appointment</a>
  </div>
</header>

<section class="doctors-page">
  <div class="page-header">
    <h2>Meet Our Specialists</h2>
    <p>Browse our doctors and book your consultation in minutes.</p>
  </div>

  <div class="doctors-container">
    <aside class="filters-sidebar">
      <form method="GET" class="filters-card">
        <h5>Filter Doctors</h5>

        <div class="filter-group">
          <label for="name-filter">Doctor Name</label>
          <input
            id="name-filter"
            type="text"
            name="name"
            value="{{ name }}"
            placeholder="Search by name..."
            class="doctors-input"
          />
        </div>

        <div class="filter-group">
          <label for="spec-filter">Specialty</label>
          <select id="spec-filter" name="specialization" class="doctors-select">
            <option value="">All Specialties</option>
            {% for spec in specializations %}
              <option value="{{ spec }}" {{ spec == specialization ? 'selected' : '' }}>{{ spec }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="filter-group">
          <label for="loc-filter">Location</label>
          <select id="loc-filter" name="location" class="doctors-select">
            <option value="">All Locations</option>
            {% for loc in locations %}
              <option value="{{ loc }}" {{ loc == location ? 'selected' : '' }}>{{ loc }}</option>
            {% endfor %}
          </select>
        </div>

        <button type="submit" class="doctors-btn doctors-btn-primary">Apply Filters</button>
      </form>
    </aside>

    <div class="doctors-grid">
      {% if doctors is empty %}
        <div class="empty-state">
          <p>No doctors found. Try adjusting your filters.</p>
        </div>
      {% else %}
        {% for doc in doctors %}
          <div class="doctors-card doctors-hover">
            <img
              src="{{ doc.imagePath ? asset('uploads/' ~ doc.imagePath) : asset('images/default_doctor.svg') }}"
              class="doctors-img"
              alt="Dr {{ doc.name }}"
            />

            <div style="padding: 1rem">
              <h5 style="margin-bottom: 0.5rem; font-weight: bold; font-size: 1.25rem">{{ doc.name }}</h5>
              <p style="color: #0d6efd; font-size: 0.875em; margin-bottom: 0.5rem">{{ doc.specialization }}</p>
              <p style="color: #6c757d; font-size: 0.875em; margin-bottom: 1rem">
                {{ doc.about ?: 'Experienced specialist ready to help.' }}
              </p>

              <div class="doctors-info-box">
                <span>Exp: <b>{{ doc.experience }}</b></span>
                <span>Location: <b>{{ doc.officePlace }}</b></span>
              </div>
            </div>

            <div style="padding: 1rem; border-top: 1px solid #f0f0f0">
              <a href="{{ path('appointments_book', { doctor_id: doc.id }) }}" class="doctors-btn doctors-btn-primary" style="margin-bottom: 0.5rem">Book Now</a>
              <a href="{{ path('doctors_view_profile', { id: doc.id }) }}" class="doctors-btn doctors-btn-outline">View Profile</a>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>

  {% if pages > 1 %}
    <nav class="pagination-wrapper">
      <ul class="pagination">
        <li class="page-item {{ page == 1 ? 'disabled' : '' }}">
          <a class="page-link"
            href="{{ path('doctors_search', {
              page: page - 1,
              specialization: specialization,
              location: location,
              name: name
            }) }}">
            Previous
          </a>
        </li>

        {% for p in 1..pages %}
          <li class="page-item {{ p == page ? 'active' : '' }}">
            <a class="page-link"
              href="{{ path('doctors_search', {
                page: p,
                specialization: specialization,
                location: location,
                name: name
              }) }}">
              {{ p }}
            </a>
          </li>
        {% endfor %}

        <li class="page-item {{ page == pages ? 'disabled' : '' }}">
          <a class="page-link"
            href="{{ path('doctors_search', {
              page: page + 1,
              specialization: specialization,
              location: location,
              name: name
            }) }}">
            Next
          </a>
        </li>
      </ul>
    </nav>

    <div class="pagination-meta">
      Page {{ page }} of {{ pages }}
    </div>
  {% endif %}
</section>

<footer>
  <p>© 2026 HealthConnect. All rights reserved.</p>
</footer>
{% endblock %}