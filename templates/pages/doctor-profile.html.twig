{% extends 'base.html.twig' %}

{% block title %}Manage Profile | HealthConnect{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/view-profile.css') }}" />
    <link rel="stylesheet" href="{{ asset('css/doctor-profile.css') }}" />
{% endblock %}

{% block body %}
<body>
    <!-- Consistent Navbar -->
    <header class="navbar">
        <div class="logo">Health <span>Connect</span></div>
        <nav class="navigation">
            <a href="{{ path('home') }}">Home</a>
            <a href="{{ path('appointments_list') }}">Dashboard</a>
        </nav>
        <div class="header-actions">
            <a href="{{ path('logout') }}" class="btn-logout">Logout</a>
        </div>
    </header>

    <main class="profile-v3">
        <div class="page-header">
            <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
                <h2 class="page-title">Manage Your Profile</h2>
                <button class="primary-btn" onclick="openEditModal()">
                    <i class="fas fa-edit"></i> Edit Details
                </button>
            </div>
        </div>

        <div class="container main-layout">
            {% if successMsg %}
                <div class="alert alert-success">{{ successMsg }}</div>
            {% endif %}
            {% if errorMsg %}
                <div class="alert alert-danger">{{ errorMsg }}</div>
            {% endif %}

            <div class="profile-card shadow-card">
                <div class="profile-main-info">
                    <div class="profile-image-section">
                        {% set displayImage = doctor.imagePath ?: 'https://cdn-icons-png.flaticon.com/512/3774/3774299.png' %}
                        <img src="{{ displayImage }}" alt="{{ doctor.name }}" class="profile-large-img">
                    </div>

                    <div class="profile-info-section">
                        <div class="title-meta">
                            <span class="specialty-badge">{{ doctor.specialization }}</span>
                            <h1>
                                {% if doctor.name starts with 'Dr.' %}
                                    {{ doctor.name }}
                                {% else %}
                                    Dr. {{ doctor.name }}
                                {% endif %}
                            </h1>
                            <div class="rating-summary">
                                <i class="fas fa-star"></i> 5.0
                                <span>(0 reviews)</span>
                            </div>
                        </div>

                        <div class="stats-grid">
                            <div class="stat-box">
                                <i class="fas fa-calendar-alt"></i>
                                <div class="stat-text">
                                    <label>Experience</label>
                                    <strong>{{ doctor.experience ?: 'Not set' }}</strong>
                                </div>
                            </div>
                            <div class="stat-box">
                                <i class="fas fa-money-bill-wave"></i>
                                <div class="stat-text">
                                    <label>Fee</label>
                                    <strong>{{ doctor.consultationFee ?: 'Not set' }}</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="profile-details-section">
                    <div class="details-cols">
                        <div class="details-main">
                            <h3 class="section-title">Public Biography</h3>
                            <p class="description-text">
                                {% if doctor.about %}
                                    {{ doctor.about|nl2br }}
                                {% else %}
                                    Your bio is currently empty. Add one to attract more patients.
                                {% endif %}
                            </p>

                            <h3 class="section-title">Workspace Details</h3>
                            <div class="facility-box">
                                <div class="facility-icon"><i class="fas fa-hospital"></i></div>
                                <div class="facility-info">
                                    <h4>{{ doctor.hospital ?: 'Hospital not set' }}</h4>
                                    <p>{{ doctor.officePlace ?: 'Office room not set' }}</p>
                                </div>
                            </div>
                        </div>

                        <div class="details-side">
                            <h3 class="section-title">Contact Information</h3>
                            <div class="contact-list">
                                <div class="contact-item">
                                    <i class="fas fa-envelope"></i>
                                    <div class="contact-data">
                                        <label>Private Email</label>
                                        <p>{{ doctor.email }}</p>
                                    </div>
                                </div>
                                <div class="contact-item">
                                    <i class="fas fa-phone"></i>
                                    <div class="contact-data">
                                        <label>Phone Number</label>
                                        <p>{{ doctor.phone }}</p>
                                    </div>
                                </div>
                                <div class="contact-item">
                                    <i class="fas fa-id-card"></i>
                                    <div class="contact-data">
                                        <label>License Number</label>
                                        <p>{{ doctor.licenseNumber }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Modal for editing -->
    <div id="editModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Update My Profile</h2>
                <span class="close-btn" onclick="closeEditModal()">&times;</span>
            </div>
            <form method="POST" enctype="multipart/form-data">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="name" value="{{ doctor.name }}" required>
                    </div>
                    <div class="form-group">
                        <label>Specialization</label>
                        <input type="text" name="specialization" value="{{ doctor.specialization }}" required>
                    </div>
                    <div class="form-group">
                        <label>Years of Experience</label>
                        <input type="text" name="experience" value="{{ doctor.experience }}" placeholder="e.g. 15+ Years">
                    </div>
                    <div class="form-group">
                        <label>Consultation Fee</label>
                        <input type="text" name="consultation_fee" value="{{ doctor.consultationFee }}" placeholder="e.g. $75">
                    </div>
                    <div class="form-group">
                        <label>Hospital/Clinic</label>
                        <input type="text" name="hospital" value="{{ doctor.hospital }}" placeholder="e.g. HeartCare Medical Center">
                    </div>
                    <div class="form-group">
                        <label>Office/Room</label>
                        <input type="text" name="office_place" value="{{ doctor.officePlace }}" placeholder="e.g. Room 402">
                    </div>
                    <div class="form-group">
                        <label>Contact Phone</label>
                        <input type="text" name="phone" value="{{ doctor.phone }}" required>
                    </div>
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" name="email" value="{{ doctor.email }}" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Professional Bio</label>
                    <textarea name="about">{{ doctor.about }}</textarea>
                </div>
                <div class="form-group">
                    <label>Update Profile Photo</label>
                    <input type="file" name="profile_image" accept="image/*">
                </div>
                <button type="submit" class="save-btn">Save Changes</button>
            </form>
        </div>
    </div>

    <footer class="footer">
        <p>&copy; 2026 HealthConnect. All rights reserved.</p>
    </footer>

    <script src="{{ asset('js/doctor-profile.js') }}"></script>
</body>
{% endblock %}
