<?php
session_start();
include '../backend/ConnexionDB.php';

if (!isset($_SESSION['role']) || $_SESSION['role'] !== 'doctor' || !isset($_SESSION['doctor_id'])) {
    header("Location: ../login_signup/login-register.php");
    exit;
}

$db = ConnexionDB::getInstance();
$doctor_id = (int) $_SESSION['doctor_id'];
$success_msg = "";
$error_msg = "";

if ($_SERVER["REQUEST_METHOD"] == "POST" && isset($_POST['update_profile'])) {
    $name = trim($_POST['name']);
    $specialization = trim($_POST['specialization']);
    $experience = trim($_POST['experience']);
    $consultation_fee = trim($_POST['consultation_fee']);
    $hospital = trim($_POST['hospital']);
    $phone = trim($_POST['phone']);
    $email = trim($_POST['email']);
    $about = trim($_POST['about']);
    $office_place = trim($_POST['office_place'] ?? '');

    // Handle Image Upload
    $image_path = null;
    if (isset($_FILES['profile_image']) && $_FILES['profile_image']['error'] === UPLOAD_ERR_OK) {
        $fileTmpPath = $_FILES['profile_image']['tmp_name'];
        $fileName = $_FILES['profile_image']['name'];
        $fileExtension = strtolower(pathinfo($fileName, PATHINFO_EXTENSION));
        $allowedExtensions = ['jpg', 'jpeg', 'png', 'gif'];

        if (in_array($fileExtension, $allowedExtensions)) {
            $uploadDir = 'uploads/';
            if (!is_dir($uploadDir)) {
                mkdir($uploadDir, 0777, true);
            }
            $newFileName = 'doctor_' . $doctor_id . '.' . $fileExtension;
            $destPath = $uploadDir . $newFileName;

            if (move_uploaded_file($fileTmpPath, $destPath)) {
                $image_path = $destPath;
            }
        }
    }

    if ($image_path) {
        $updateStmt = $db->prepare("UPDATE Doctor SET name = ?, specialization = ?, experience = ?, consultation_fee = ?, hospital = ?, phone = ?, email = ?, about = ?, office_place = ?, image_path = ? WHERE id = ?");
        $params = [$name, $specialization, $experience, $consultation_fee, $hospital, $phone, $email, $about, $office_place, $image_path, $doctor_id];
    } else {
        $updateStmt = $db->prepare("UPDATE Doctor SET name = ?, specialization = ?, experience = ?, consultation_fee = ?, hospital = ?, phone = ?, email = ?, about = ?, office_place = ? WHERE id = ?");
        $params = [$name, $specialization, $experience, $consultation_fee, $hospital, $phone, $email, $about, $office_place, $doctor_id];
    }

    if($updateStmt->execute($params)) {
        $success_msg = "Profile updated successfully!";
    } else {
        $error_msg = "Failed to update profile.";
    }
}

$stmt = $db->prepare("SELECT id, name, email, phone, specialization, license_number, experience, consultation_fee, hospital, about, rating, reviews, image_path, office_place FROM Doctor WHERE id = ? LIMIT 1");
$stmt->execute([$doctor_id]);
$doctor = $stmt->fetch(PDO::FETCH_ASSOC);

$placeholderImage = "https://cdn-icons-png.flaticon.com/512/3774/3774299.png";
$displayImage = ($doctor && !empty($doctor['image_path'])) ? $doctor['image_path'] : $placeholderImage;
