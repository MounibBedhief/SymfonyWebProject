<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>
        {% if doctor.name starts with 'Dr.' %}
            {{ doctor.name }}
        {% else %}
            Dr. {{ doctor.name }}
        {% endif %} | HealthConnect
    </title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="{{ asset('css/view-profile.css') }}" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<header class="navbar">
    <div class="logo">Health <span>Connect</span></div>
    <nav class="navigation">
        <a href="{{ path('home') }}">Home</a>
        <a href="{{ path('doctors_search') }}">Specialists</a>
        <a href="{{ path('dashboard') }}">Dashboard</a>
    </nav>
    <div class="header-actions">
        <a href="{{ path('appointments_book', { doctor_id: doctor.id }) }}" class="btn-top-book">Book Appointment</a>
    </div>
</header>

<main class="profile-v3">
    <div class="page-header">
        <div class="container">
            <h2 class="page-title">Doctor Profile</h2>
        </div>
    </div>

    <div class="container main-layout">
        <div class="profile-card shadow-card">
            <div class="profile-main-info">
                <div class="profile-image-section">
                    <img src="{{ doctor.imagePath ? asset(doctor.imagePath) : 'https://cdn-icons-png.flaticon.com/512/3774/3774299.png' }}" alt="{{ doctor.name }}" class="profile-large-img">
                </div>

                <div class="profile-info-section">
                    <div class="title-meta">
                        <span class="specialty-badge">{{ doctor.specialization }}</span>
                        <h1>
                            {% if doctor.name starts with 'Dr.' %}
                                {{ doctor.name }}
                            {% else %}
                                Dr. {{ doctor.name }}
                            {% endif %}
                        </h1>
                        <div class="rating-summary">
                            <i class="fas fa-star"></i> {{ doctor.rating|default('5.0') }}
                            <span>({{ doctor.reviews|default('0') }} reviews)</span>
                        </div>
                    </div>

                    <div class="stats-grid">
                        <div class="stat-box">
                            <i class="fas fa-calendar-alt"></i>
                            <div class="stat-text">
                                <label>Experience</label>
                                <strong>{{ doctor.experience ? doctor.experience ~ ' Years' : '10+ Years' }}</strong>
                            </div>
                        </div>
                        <div class="stat-box">
                            <i class="fas fa-money-bill-wave"></i>
                            <div class="stat-text">
                                <label>Consultation Fee</label>
                                <strong>{{ doctor.consultationFee ? doctor.consultationFee ~ ' DT' : '50 DT' }}</strong>
                            </div>
                        </div>
                    </div>

                    <div class="cta-section">
                        <a href="{{ path('appointments_book', { doctor_id: doctor.id }) }}" class="primary-btn">Book Appointment Now</a>
                    </div>
                </div>
            </div>

            <div class="profile-details-section">
                <div class="details-cols">
                    <div class="details-main">
                        <h3 class="section-title">About Doctor</h3>
                        <p class="description-text">{{ doctor.about ? doctor.about|nl2br : 'A dedicated professional providing top-tier medical assistance.' }}</p>

                        <h3 class="section-title">Location & Facility</h3>
                        <div class="facility-box">
                            <div class="facility-icon"><i class="fas fa-hospital"></i></div>
                            <div class="facility-info">
                                <h4>{{ doctor.hospital|default('HealthConnect Central') }}</h4>
                                <p>{{ doctor.officePlace|default('Consultation Room') }}</p>
                            </div>
                        </div>
                    </div>

                    <div class="details-side">
                        <h3 class="section-title">Contact Information</h3>
                        <div class="contact-list">
                            <div class="contact-item">
                                <i class="fas fa-envelope"></i>
                                <div class="contact-data">
                                    <label>Email Address</label>
                                    <p>{{ doctor.email }}</p>
                                </div>
                            </div>
                            <div class="contact-item">
                                <i class="fas fa-phone"></i>
                                <div class="contact-data">
                                    <label>Phone Number</label>
                                    <p>{{ doctor.phone|default('N/A') }}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<footer class="footer">
    <p>&copy; 2026 HealthConnect. All rights reserved.</p>
</footer>
</body>
</html>
