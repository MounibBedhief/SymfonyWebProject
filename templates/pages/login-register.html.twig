<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HealthConnect - Connexion</title>
    <link rel="stylesheet" href="{{ asset('css/login-signup.css') }}" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="{{ asset('js/Login-register.js') }}" defer></script>
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
</head>
<body>
    <header>
        <h2 class="logo">Health<span>Connect</span></h2>
        <nav class="navigation">
            <a href="{{ path('home') }}" class="btn-home">Home</a>
        </nav>
    </header>

    <div class="wrapper">
        {# Error/Success Messages #}
        {% if error %}
            <div class="alert alert-danger">{{ error }}</div>
        {% endif %}

        <div class="form-box-login" style="display: {{ showRegisterForm ? 'none' : 'block' }}">
            <h2>Welcome Back</h2>
            <form action="{{ path('login') }}" method="POST">
                <input type="hidden" name="csrf_token" value="{{ csrf_token('auth_token') }}">

                <div class="input-box">
                    <input type="email" name="email" required />
                    <label>Email Address</label>
                </div>

                <div class="input-box">
                    <input type="password" name="password" required />
                    <label>Password</label>
                </div>

                <button type="submit" name="login_submit" class="btn-main">Login</button>
                <div class="login-register">
                    <p>Don't have an account? <a href="#" class="register_link">Register here</a></p>
                </div>
            </form>
        </div>

        <div class="form-box-register" style="display: {{ showRegisterForm ? 'block' : 'none' }}">
            <h2>Create Account</h2>
            <form action="{{ path('login') }}" method="POST">
                <input type="hidden" name="csrf_token" value="{{ csrf_token('auth_token') }}">

                <div class="input-box">
                    <input type="text" name="Rfull_name" required />
                    <label>Full Name</label>
                </div>

                <div class="input-box">
                    <input type="email" name="Remail" required />
                    <label>Email Address</label>
                </div>

                <div class="input-box">
                    <input type="password" name="Rpassword" required />
                    <label>Password</label>
                </div>

                <div class="input-box select-box">
                    <select class="form-select" name="Rrole" required>
                        <option value="patient">Patient</option>
                        <option value="doctor">Doctor</option>
                    </select>
                </div>

                <button type="submit" name="register_submit" class="btn-main">Register</button>
                <div class="login-register">
                    <p>Already have an account? <a href="#" class="login_link">Login here</a></p>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
