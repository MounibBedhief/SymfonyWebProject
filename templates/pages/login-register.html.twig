<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HealthConnect - Connexion</title>
    <link rel="stylesheet" href="{{ asset('css/login-signup.css') }}" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="{{ asset('js/Login-register.js') }}" defer></script>
    <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
</head>
<body>
<header>
    <h2 class="logo">Health<span>Connect</span></h2>
    <nav class="navigation">
        <a href="{{ path('home') }}" class="btn-home">Home</a>
    </nav>
</header>

<div class="wrapper {{ showRegisterForm ? 'active' : '' }}">

    {# ✅ CORRECTION : Pop-up JavaScript en cas de mauvais mot de passe / identifiants #}
    <div class="form-box-login">
        {# ✅ À MODIFIER : On enveloppe l'alerte pour forcer un retour à la ligne complet #}
        {% if has_error %}
            <div style="width: 100%; display: block; margin-bottom: 15px;">
                <div class="alert alert-danger alert-dismissible fade show" role="alert" style="font-size: 14px; margin: 0 auto; width: 100%;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2" viewBox="0 0 16 16">
                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                    </svg>
                    Email or password incorrect.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        {% endif %}
        <form action="{{ path('login') }}" method="POST">
            {# Le reste de ton formulaire reste inchangé... #}

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <div class="form-box-login">
        <h2>Welcome Back</h2>
        <form action="{{ path('login') }}" method="POST">
            {# ✅ CORRECTION : CORRESPONDANCE STRICTE AVEC LE SECURITY.YAML #}
            <input type="hidden" name="csrf_token" value="{{ csrf_token('auth_token') }}">

            <div class="input-box">
                {# ✅ Doit être name="email" et non name="_username" #}
                <input type="email" name="email" value="{{ last_username }}" required />
                <label>Email Address</label>
            </div>

            <div class="input-box">
                {# ✅ Doit être name="password" et non name="_password" #}
                <input type="password" name="password" required />
                <label>Password</label>
            </div>

            <button type="submit" name="login_submit" class="btn-main">Login</button>
            <div class="login-register">
                <p>Don't have an account? <a href="#" class="register_link">Register here</a></p>
            </div>
        </form>
    </div>

    <div class="form-box-register">
        <h2>Create Account</h2>

        {{ form_start(registerForm, {'action': path('register'), 'method': 'POST'}) }}

        {{ form_errors(registerForm) }}

        <div class="input-box">
            {{ form_widget(registerForm.full_name, {'attr': {'required': 'required'}}) }}
            <label>Full Name</label>
            {{ form_errors(registerForm.full_name) }}
        </div>

        <div class="input-box">
            {{ form_widget(registerForm.email, {'attr': {'required': 'required'}}) }}
            <label>Email Address</label>
            {{ form_errors(registerForm.email) }}
        </div>

        <div class="input-box">
            {{ form_widget(registerForm.plainPassword.first, {'attr': {'required': 'required'}}) }}
            <label>Password</label>
            {{ form_errors(registerForm.plainPassword.first) }}
        </div>

        <div class="input-box">
            {{ form_widget(registerForm.plainPassword.second, {'attr': {'required': 'required'}}) }}
            <label>Confirm Password</label>
            {{ form_errors(registerForm.plainPassword.second) }}
        </div>

        <div class="input-box select-box">
            {{ form_widget(registerForm.role, {'attr': {'class': 'form-select', 'required': 'required'}}) }}
            {{ form_errors(registerForm.role) }}
        </div>

        <button type="submit" class="btn-main">Register</button>

        <div class="login-register">
            <p>Already have an account? <a href="#" class="login_link">Login here</a></p>
        </div>

        {{ form_end(registerForm) }}
    </div>
</div>
</body>
</html>
